# Database
DATABASE_URL=file:/app/data/cleancheck.db

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-secret-in-production-use-openssl-rand-base64-32

# Application
NODE_ENV=production

# Email Notifications (Resend)
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=CleanCheck <noreply@yourdomain.com>

# Cron Job Security
# Used to secure the /api/cron endpoint
CRON_SECRET=your-random-cron-secret
