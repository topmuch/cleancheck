# Database
DATABASE_URL=file:/app/data/cleancheck.db

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-secret-in-production-use-openssl-rand-base64-32

# Application
NODE_ENV=production

# Email Notifications (Resend)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=CleanCheck <noreply@yourdomain.com>

# Cron Job Security
CRON_SECRET=your-random-cron-secret

# File Upload (optional - for photos, documents)
# UPLOAD_DIR=/app/uploads

# Maps/Geocoding (optional - for distance calculation)
# GOOGLE_MAPS_API_KEY=your-google-maps-key
